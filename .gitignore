# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# media & data
*.mp4
*.m4a
*.mp3
*.wav
*.flac

# logs
build_log*.txt
build_output.txt

# scratch
scratch/
_frames/
_frames_detail/
*.ate

# docs to exclude
*.txt
ARCHITECTURE.md
SLOWI_MUSIC_DEV_STATE.md
.expo/README.md
